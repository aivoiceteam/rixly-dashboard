# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# FIREBASE_PROJECT_ID: The ID of your Firebase project.
FIREBASE_PROJECT_ID=""

# SANITY_PROJECT_ID: Your Sanity project ID
SANITY_PROJECT_ID=""
# SANITY_DATASET: Your Sanity dataset (e.g., "production")
SANITY_DATASET="production"
# SANITY_API_TOKEN: Your Sanity API token with write permissions
SANITY_API_TOKEN=""

# VITE_APP_PASSWORD: Frontend dashboard login password.
# Must start with VITE_ to be available in React via import.meta.env.
VITE_APP_PASSWORD="change-me"

# Optional: use one stable instance id so queue/settings are shared across browsers/devices.
# If omitted, each browser gets its own local instance id and will see a separate queue.
VITE_RIXLY_INSTANCE_ID="team-main"

# Railway runtime port (Railway sets this automatically).
PORT=3000

# Frontend domain allowed to call this backend in production.
# Example: FRONTEND_ORIGIN=https://your-frontend.up.railway.app
FRONTEND_ORIGIN="*"
